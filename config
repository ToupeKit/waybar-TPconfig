{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 0,
  "exclusive": true,
  "fixed-center": true,
  "margin-top": 2,
  "margin-bottom": 100,
  "margin-left": 10,
  "margin-right": 10,

  "modules-left": [
    "cpu",
    "memory",
    "temperature",
    "custom/separator",
    "power-profiles-daemon"
  ],

  "modules-center": [
    "hyprland/workspaces"
  ],

  "modules-right": [
    "network",
    "custom/separator",
    "tray",
    "battery",
    "clock"
  ],

  "cpu": {
    "interval": 2,
    "format": "у∞НЫ {usage}%",
    "tooltip": false
  },

  "memory": {
    "interval": 2,
    "format": "у∞ЊЖ {percentage}%",
    "tooltip-format": "{used:0.1f} GB / {total:0.1f} GB",
    "warning": 75,
    "critical": 90
  },

  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
    "interval": 2,
    "critical-threshold": 80,
    "format": "{icon} {temperatureC}¬∞",
    "format-icons": ["у∞ЬЧ", "у∞ЬЧ", "у∞ЬЧ"],
    "tooltip": true
  },

  "hyprland/workspaces": {
    "format": "{id}",
    "on-click": "activate",
    "all-outputs": false,
    "active-only": false,
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    },
    "sort-by-number": true
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "–Я—А–Њ—Д–Є–ї—М: {profile}\n–Ф—А–∞–є–≤–µ—А: {driver}",
    "tooltip": true,
    "format-icons": {
      "default":      "у±РЛ",
      "performance":  "у±РЛ",
      "balanced":     "у∞ЊЕ",
      "power-saver":  "у∞М™"
    }
  },

  "network": {
    "interval": 5,
    "format-wifi": "у∞§®  {essid}",
    "format-ethernet": "у∞ИА  {ipaddr}",
    "format-disconnected": "у∞§≠  Offline",
    "tooltip-format": "IP: {ipaddr}\n–°–Є–≥–љ–∞–ї: {signalStrength}%\n–°–Ї–Њ—А–Њ—Б—В—М: вЖУ{bandwidthDownBits} вЖС{bandwidthUpBits}",
    "on-click": "networkmanager_dmenu"
  },

  "tray": {
    "icon-size": 15,
    "spacing": 6
  },

  "battery": {
    "interval": 10,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "у∞ВД {capacity}%",
    "format-plugged": "у∞Ъ• {capacity}%",
    "format-icons": ["у∞БЇ", "у∞БЉ", "у∞БЊ", "у∞ВА", "у∞Бє"],
    "tooltip-format": "{time} ¬Ј {power:.1f}W"
  },

  "clock": {
    "interval": 1,
    "format": "у∞•Ф  {:%H:%M}",
    "format-alt": "у∞Г≠  {:%a, %d %b %Y}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "left",
      "format": {
        "today": "<span color='#fab387'><b>{}</b></span>"
      }
    }
  },

  "custom/separator": {
    "format": "вФВ",
    "tooltip": false
  }
}
